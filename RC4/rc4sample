// This is what SystemFunction032 function takes as parameters, get this info from google, first link is https://s3cur3th1ssh1t.github.io/SystemFunction032_Shellcode/
typedef struct _USTRING
{
	DWORD	Length;
	DWORD	MaximumLength;
	PVOID	Buffer;

} USTRING;


// Define the SystemFunction032 function 
typedef NTSTATUS(NTAPI* fnSystemFunction032)(
	USTRING* Data,
	USTRING* Key
	);


BOOL Rc4EncryptionViSystemFunc032(IN PBYTE pRc4Key, IN PBYTE pPayloadData, IN DWORD dwRc4KeySize, IN DWORD sPayloadSize) {

	//return value of SystemFunction032
	NTSTATUS	STATUS = NULL;

	// Making 2 USTRING variables
	// 1 is passed as the key and the other one is passed as the block of data to encrypt/decrypt
	USTRING Key {};
	Key.Buffer = pRc4Key;
	Key.Length = dwRc4KeySize;
	Key.MaximumLength = dwRc4KeySize;
	
	USTRING Data {};
	Data.Buffer = pPayloadData;
	Data.Length = sPayloadSize;
	Data.MaximumLength = sPayloadSize;


	// Since SystemFunction032 is exported from Advapi32.dll, use LoadLibraryA to load Advapi32.dll into the process, 
	// And use LoadLibraryA's return value as the hModule parameter in GetProcAddress
	fnSystemFunction032 SystemFunction032 = (fnSystemFunction032)GetProcAddress(LoadLibraryA("Advapi32"), "SystemFunction032");

	// If the SystemFunction032 invocation failed, it will return a non-zero value 
	if ((STATUS = SystemFunction032(&Data, &Key)) != 0x0) {
		printf("[!] SystemFunction032 FAILED With Error: 0x%0.8X \n", STATUS);
		return FALSE;
	}

	return TRUE;
}

